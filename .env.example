# ============================================================
# dobrostanSTUDIOvisualisation — wymagane zmienne środowiskowe
# Lokalnie: skopiuj do .env.local | Na Vercel: Settings → Environment Variables
# ============================================================

# --- Hasło do aplikacji (WYMAGANE na produkcji) ---
# Dowolny ciąg znaków. Bez niego aplikacja jest otwarta (tryb dev).
APP_PASSWORD=

# --- Anthropic (warstwa tłumaczenia poleceń, Claude Fable 5) ---
# Skąd wziąć: https://platform.claude.com → Settings → API Keys
ANTHROPIC_API_KEY=
# Opcjonalnie: inny model, np. claude-opus-4-8 (tańszy). Domyślnie claude-fable-5.
# ANTHROPIC_MODEL=claude-fable-5
# Opcjonalnie: głębokość rozumowania przy tłumaczeniu poleceń (low|medium|high).
# "low" (domyślne) wystarcza i mocno tnie koszt tokenów wyjściowych.
# ANTHROPIC_EFFORT=low
# Opcjonalnie: maks. rozmiar obrazu wysyłanego do Claude (px, dłuższy bok).
# 1024 (domyślne) tnie tokeny wizji ~4x względem pełnej rozdzielczości.
# ANTHROPIC_IMAGE_MAX_PX=1024

# --- fal.ai (FLUX — główny model graficzny + upscaling) ---
# Skąd wziąć: https://fal.ai/dashboard/keys
FAL_KEY=
# Opcjonalne nadpisania modeli fal:
# FAL_MODEL_STANDARD=fal-ai/flux-pro/kontext          # jakość "Szybka (test)"
# FAL_MODEL_HIGH=fal-ai/flux-pro/kontext/max          # jakość "Wysoka"
# FAL_MODEL_FILL=fal-ai/flux-pro/v1/fill              # inpainting zaznaczonych obszarów
# FAL_MODEL_MULTI=fal-ai/flux-pro/kontext/max/multi   # edycja z obiektami referencyjnymi
# FAL_MODEL_UPSCALE=fal-ai/aura-sr                    # dociąganie do finalnej rozdzielczości
# Opcjonalne stawki w USD pokazywane w liczniku kosztów:
# FLUX_STANDARD_COST_USD=0.04
# FLUX_COST_USD=0.08
# FLUX_FILL_COST_USD=0.05
# FLUX_MULTI_COST_USD=0.08
# UPSCALE_COST_USD=0.02

# --- Google AI Studio (Nano Banana Pro — fallback, OPCJONALNE) ---
# Skąd wziąć: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# GEMINI_COST_USD=0.139       # jakość "Szybka (test)", 1K
# GEMINI_4K_COST_USD=0.24     # jakość "Wysoka", natywne 4K

# --- Wybór domyślnego modelu graficznego: flux | gemini ---
IMAGE_PROVIDER=flux

# Jakość "Wysoka" oddaje obraz w dokładnie tych samych wymiarach co edytowany
# obraz wejściowy (upscaling AuraSR, gdy model wygenerował mniej).

# --- Vercel Blob (storage obrazów) ---
# Na Vercel: Storage → Create Database → Blob → podepnij do projektu,
# token BLOB_READ_WRITE_TOKEN doda się automatycznie.
# Lokalnie: skopiuj token z Vercel (Settings → Environment Variables) albo `vercel env pull`.
# Bez tokenu aplikacja działa na data-URL-ach (tylko do testów, zapycha localStorage).
BLOB_READ_WRITE_TOKEN=
